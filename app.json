{
    "expo":  {
                 "name":  "MasterFabric",
                 "slug":  "masterfabric-expo",
                 "description":  "Modern mobile platform for fabric design and management applications",
                 "version":  "1.0.0",
                 "orientation":  "portrait",
                 "icon":  "./src/assets/images/app_icon.png",
                 "scheme":  "masterfabricexpo",
                 "userInterfaceStyle":  "automatic",
                 "newArchEnabled":  true,
                 "primaryColor":  "#000000",
                 "splash":  {
                                "image":  "./src/assets/images/splash-icon.png",
                                "resizeMode":  "contain",
                                "backgroundColor":  "#000000"
                            },
                 "ios":  {
                             "supportsTablet":  true,
                             "icon":  "./src/assets/images/app_icon.png",
                             "bundleIdentifier":  "com.masterfabric.expo.ios",
                             "buildNumber":  "3",
                             "infoPlist":  {
                                 "CFBundleAllowMixedLocalizations":  true
                             }
                         },
                 "locales":  {
                             "en":  "./locales/ios/en.json",
                             "tr":  "./locales/ios/tr.json"
                         },
                 "android":  {
                                 "adaptiveIcon":  {
                                                      "foregroundImage":  "./src/assets/images/app_icon.png",
                                                      "backgroundColor":  "#ffffff"
                                                  },
                                 "edgeToEdgeEnabled":  true,
                                 "package":  "com.masterfabric.expo.android",
                                 "versionCode":  3,
"permissions":  [
                                                    "android.permission.CAMERA",
                                                    "android.permission.RECORD_AUDIO",
                                                    "android.permission.READ_EXTERNAL_STORAGE",
                                                    "android.permission.WRITE_EXTERNAL_STORAGE",
                                                    "android.permission.READ_MEDIA_IMAGES",
                                                    "android.permission.READ_MEDIA_VIDEO",
                                                    "android.permission.ACCESS_FINE_LOCATION",
                                                    "android.permission.ACCESS_COARSE_LOCATION",
                                                    "android.permission.ACCESS_BACKGROUND_LOCATION",
                                                    "android.permission.POST_NOTIFICATIONS",
                                                    "android.permission.READ_CONTACTS",
                                                    "android.permission.WRITE_CONTACTS",
                                                    "android.permission.READ_CALENDAR",
                                                    "android.permission.WRITE_CALENDAR",
                                                    "android.permission.READ_PHONE_STATE",
                                                    "android.permission.READ_SMS",
                                                    "android.permission.RECEIVE_SMS",
                                                    "android.permission.BLUETOOTH_CONNECT",
                                                    "android.permission.BLUETOOTH_SCAN",
                                                    "android.permission.BLUETOOTH_ADVERTISE",
                                                    "android.permission.SEND_SMS",
                                                    "android.permission.READ_MEDIA_AUDIO",
                                                    "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
                                                    "android.permission.BODY_SENSORS"
                                                ]
                             },
                 "web":  {
                             "bundler":  "metro",
                             "output":  "static",
                             "favicon":  "./src/assets/images/favicon.png"
                         },
                 "plugins":  [
                                 "./plugins/add-media-permissions.js",
                                 "expo-router",
                                 "expo-dev-client",
                                 [
                                     "expo-splash-screen",
                                     {
                                         "image":  "./src/assets/images/splash-icon.png",
                                         "imageWidth":  200,
                                         "resizeMode":  "contain",
                                         "backgroundColor":  "#ffffff"
                                     }
                                 ],
                                 [
                                     "expo-media-library",
                                     {
                                         "photosPermission":  "The app needs gallery access to select photos and videos.",
                                         "savePhotosPermission":  "The app needs permission to save photos to your library.",
                                         "isAccessMediaLocationEnabled":  false,
                                         "granularPermissions":  ["photo", "video"]
                                     }
                                 ],
                                 [
                                     "expo-image-picker",
                                     {
                                         "photosPermission":  "The app needs gallery access to select photos and videos.",
                                         "cameraPermission":  "The app needs camera access to take photos and videos.",
                                         "microphonePermission":  "The app needs microphone access for video recording."
                                     }
                                 ],
                                 [
                                     "expo-av",
                                     {
                                         "microphonePermission":  "The app needs microphone access for audio recording."
                                     }
                                 ],
                                 [
                                     "expo-calendar",
                                     {
                                         "calendarPermission":  "The app needs calendar access to plan events."
                                     }
                                 ],
                                [
                                    "expo-contacts",
                                    {
                                        "contactsPermission": "The app needs access to your contacts to share content."
                                    }
                                ],
                                [
                                    "expo-local-authentication",
                                    {
                                        "faceIDPermission": "Allow the app to use Face ID for secure sign-in."
                                    }
                                ]
                            ],
                 "experiments":  {
                                     "typedRoutes":  true
                                 },
                 "extra":  {
                               "router":  {

                                          },
                               "eas":  {
                                           "projectId":  "da5b233a-cb42-4494-94c7-2b1427d32ebf"
                                       }
                           },
                 "owner":  "gurkanfikretgunak"
             }
}
