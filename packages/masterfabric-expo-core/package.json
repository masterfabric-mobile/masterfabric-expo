{
  "name": "masterfabric-expo-core",
  "version": "1.0.0",
  "description": "Core view architecture and utilities for MasterFabric Expo applications",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./auto-init": {
      "import": "./dist/auto-init.js",
      "types": "./dist/auto-init.d.ts"
    },
    "./setup": {
      "import": "./dist/setup.js",
      "types": "./dist/setup.d.ts"
    },
    "./polyfills": {
      "import": "./dist/polyfills.js",
      "types": "./dist/polyfills.d.ts"
    }
  },
  "bin": {
    "create-masterfabric-app": "./bin/create-masterfabric-app"
  },
  "files": [
    "dist/**/*",
    "templates/**/*",
    "scripts/**/*",
    "bin/**/*"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "create-app": "node scripts/create-masterfabric-app.js"
  },
  "keywords": [
    "react-native",
    "expo",
    "view-architecture",
    "masterview",
    "typescript",
    "zustand",
    "navigation"
  ],
  "author": "MasterFabric",
  "peerDependencies": {
    "@expo/vector-icons": ">=13.0.0",
    "@react-native-async-storage/async-storage": ">=1.0.0",
    "@sentry/react-native": ">=5.0.0",
    "@supabase/supabase-js": ">=2.0.0",
    "expo": ">=49.0.0",
    "expo-battery": ">=7.0.0",
    "expo-constants": ">=14.0.0",
    "expo-device": ">=5.0.0",
    "expo-haptics": ">=13.0.0",
    "expo-notifications": ">=0.28.0",
    "expo-router": ">=2.0.0",
    "expo-web-browser": ">=13.0.0",
    "firebase": ">=10.0.0",
    "react": "19.1.0",
    "react-native": ">=0.70.0",
    "react-native-safe-area-context": ">=4.0.0",
    "react-native-screens": ">=3.0.0",
    "zustand": ">=4.0.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "@types/react-native": "^0.72.0",
    "typescript": "^5.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/masterfabric-mobile/masterfabric-expo.git",
    "directory": "packages/masterfabric-expo-core"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "dependencies": {
    "glob": "^13.0.0",
    "minimatch": "^10.2.1",
    "react-native-get-random-values": "~1.11.0"
  },
  "overrides": {
    "minimatch": "^10.2.1",
    "glob": "^13.0.0"
  }
}
