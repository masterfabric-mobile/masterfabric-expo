{
  "name": "masterfabric-expo",
  "displayName": "MasterFabric",
  "description": "Modern mobile app development platform for creating fabric design and management applications",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "stage": "development",
  "author": {
    "name": "Gürkan Fikret Günak",
    "email": "gurkanfikretgunak@masterfabric.co"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/masterfabric-mobile/masterfabric-expo.git"
  },
  "keywords": [
    "react-native",
    "expo",
    "fabric-design",
    "mobile-app",
    "typescript",
    "masterfabric"
  ],
  "license": "AGPL-3.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "clean:android": "node -e \"const fs=require('fs'),p='android/app/build',q='android/build';[p,q].forEach(d=>{try{fs.rmSync(d,{recursive:true});console.log('Removed '+d)}catch(e){}})\"",
    "clean:ios": "node -e \"const fs=require('fs'),d='ios/build';try{fs.rmSync(d,{recursive:true});console.log('Removed '+d)}catch(e){}\"",
    "clean": "npm run clean:android && npm run clean:ios",
    "xcode": "open ios/MasterFabric.xcworkspace",
    "web": "expo start --web",
    "build:ios": "./scripts/build-ipa.sh",
    "build:ios:eas": "./scripts/build-ipa.sh eas",
    "build:ios:local": "./scripts/build-ipa.sh local",
    "build:ios:manual": "./scripts/build-ipa.sh manual",
    "build:ios:pipeline": "./scripts/build-ipa-pipeline.sh",
    "build:ios:check": "./scripts/check-build-setup.sh",
    "build:android": "./scripts/build-aab-pipeline.sh",
    "build:android:check": "./scripts/check-android-setup.sh",
    "simulator:install": "./scripts/install-simulator.sh",
    "lint": "expo lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/slider": "5.0.1",
    "@react-native-firebase/app": "^23.8.6",
    "@react-native-firebase/messaging": "^23.8.6",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.9.2",
    "@react-navigation/native": "^7.1.8",
    "@sentry/react-native": "~7.2.0",
    "@tanstack/react-query": "^5.90.12",
    "expo": "^54.0.27",
    "expo-av": "~16.0.8",
    "expo-battery": "~10.0.8",
    "expo-blur": "~15.0.8",
    "expo-build-properties": "^55.0.9",
    "expo-calendar": "~14.0.6",
    "expo-constants": "~18.0.11",
    "expo-contacts": "~15.0.11",
    "expo-dev-client": "~6.0.20",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.10",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.9",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.10",
    "expo-local-authentication": "~15.0.0",
    "expo-localization": "~17.0.8",
    "expo-location": "~18.0.8",
    "expo-media-library": "~18.2.1",
    "expo-notifications": "~0.32.0",
    "expo-router": "~6.0.17",
    "expo-splash-screen": "~31.0.12",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "firebase": "^12.8.0",
    "i18n-js": "^4.5.1",
    "jest-expo": "~54.0.17",
    "masterfabric-expo-core": "workspace:*",
    "onesignal-expo-plugin": "^2.1.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-get-random-values": "^2.0.0",
    "react-native-onesignal": "^5.3.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-wheel-color-picker": "^1.3.1",
    "react-native-worklets": "0.5.1",
    "zod": "^4.1.13",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@expo/ngrok": "^4.1.3",
    "@testing-library/react-native": "^13.2.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.10",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "eslint": "^9.39.1",
    "eslint-config-expo": "^10.0.0",
    "jest": "~29.7.0",
    "prettier": "^3.7.4",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "ajv": "^8.18.0",
    "minimatch": "^10.2.1",
    "glob": "^13.0.0"
  },
  "private": true
}
